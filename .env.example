# =========================================================================
# Doubles — environment template. Copy to `.env` and fill in real values.
# NEVER commit a real .env. NEVER put secrets in the client. Server-side only.
# The scaffold runs fully with AI_PROVIDER=mock and NO Anthropic key.
# =========================================================================

# ---- AI ------------------------------------------------------------------
# mock = deterministic, no network, no key (default). claude = real Anthropic.
AI_PROVIDER=mock
# Required only when AI_PROVIDER=claude. Get one at https://console.anthropic.com
# Do NOT paste a real key here in a committed file.
ANTHROPIC_API_KEY=

# Model routing (defaults shown; override if needed)
DOUBLES_MODEL_PLAN=claude-sonnet-4-6
DOUBLES_MODEL_BEAT=claude-haiku-4-5
DOUBLES_MODEL_RECAP=claude-haiku-4-5
# Use the Batch API for nightly generation (50% cheaper). true|false
DOUBLES_USE_BATCH=true

# ---- Supabase ------------------------------------------------------------
# From the Supabase dashboard → Project Settings → API.
SUPABASE_URL=http://127.0.0.1:54321
# Publishable (anon) key — safe for clients.
SUPABASE_ANON_KEY=
# Service-role key — SERVER ONLY. Never ship to a client. Bypasses RLS.
SUPABASE_SERVICE_ROLE_KEY=
# Direct Postgres connection string (used by seed + type generation).
SUPABASE_DB_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres
# Project ref (e.g. abcdefgh...) — used by `supabase gen types`.
SUPABASE_PROJECT_REF=

# ---- Jobs ----------------------------------------------------------------
# Shared secret protecting POST /jobs/run-episode/:worldId (Bearer token).
JOB_SECRET=dev-change-me

# ---- Engine tuning -------------------------------------------------------
DOUBLES_BEAT_CAP=12
DOUBLES_TOKEN_BUDGET=120000
