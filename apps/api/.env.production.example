# Environment variables to set in the Vercel project (Project → Settings →
# Environment Variables). These are SERVER-SIDE only — never shipped to the client.
# Copy the values from your Supabase dashboard (Project Settings → API).

SUPABASE_URL=https://ctouykgmzmqoabhmlzcq.supabase.co
SUPABASE_ANON_KEY=            # publishable / anon key
SUPABASE_SERVICE_ROLE_KEY=    # service_role secret — bypasses RLS, server only
JOB_SECRET=                   # any long random string; the Supabase cron uses the same value

# AI: keep mock for a free, deterministic demo. For real beats use claude WITHOUT batch
# on Vercel Hobby (batch polls for minutes and would exceed the 60s function limit).
AI_PROVIDER=mock
# ANTHROPIC_API_KEY=         # only if AI_PROVIDER=claude
DOUBLES_USE_BATCH=false
